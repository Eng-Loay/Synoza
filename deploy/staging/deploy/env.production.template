# Production — copy to server/.env on the host (DO NOT commit real secrets to git)

PORT=5000
NODE_ENV=production
JWT_SECRET=CHANGE-TO-LONG-RANDOM-SECRET
JWT_EXPIRES_IN=7d
CLIENT_URL=https://synoza.anmka.com

# MySQL (cPanel) — URL-encode special chars in password (+ → %2B, = → %3D)
DATABASE_URL="mysql://DB_USER:DB_PASSWORD_ENCODED@localhost:3306/DB_NAME"

AI_PROVIDER=openai
OPENAI_API_KEY=your-openai-key
OPENAI_MODEL=gpt-realtime-mini
OPENAI_WHISPER_MODEL=gpt-4o-transcribe
OPENAI_REALTIME_MODEL=gpt-realtime-mini
OPENAI_REALTIME_TRANSCRIBE_MODEL=gpt-4o-transcribe

ADMIN_EMAIL=admin@synoza.com
ADMIN_PASSWORD=ChangeMeAfterDeploy

# SMTP (signup OTP verification)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=app@anmka.com
SMTP_PASS=CHANGE-SMTP-PASSWORD
SMTP_FROM=app@anmka.com
SMTP_FROM_NAME=Synoza

# Payment — Paymob Accept
PAYMENT_PROVIDER=paymob
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=
PAYMOB_CURRENCY=EGP
PAYMENT_CALLBACK_BASE_URL=https://synoza.anmka.com
