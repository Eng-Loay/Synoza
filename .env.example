# Server
PORT=5000
NODE_ENV=development
JWT_SECRET=change-this-to-a-long-random-secret-key
JWT_EXPIRES_IN=365d
CLIENT_URL=http://localhost:5173

# Database — SQLite (default) OR MySQL
DATABASE_URL="file:./dev.db"
# DATABASE_URL="mysql://synoza_user:Synoza%402026@localhost:3306/synoza"

# AI Provider (openai | gemini | mock)
AI_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-5-mini
GEMINI_API_KEY=

# Admin seed credentials
ADMIN_EMAIL=admin@synoza.com
ADMIN_PASSWORD=Admin@123456

# SMTP (email verification OTP)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=app@anmka.com
SMTP_PASS=your-smtp-password
SMTP_FROM=app@anmka.com
SMTP_FROM_NAME=Synoza

# Payment gateway (Paymob Accept — Egypt)
# Default: paymob (add keys below). Use mock for local testing without keys.
PAYMENT_PROVIDER=paymob
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=
PAYMOB_CURRENCY=EGP
# Public URL Paymob redirects to after payment (production API URL)
PAYMENT_CALLBACK_BASE_URL=
